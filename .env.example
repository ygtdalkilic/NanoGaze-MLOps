MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
GEMINI_API_KEY=your_gemini_api_key_here

# Tunable defaults
GEMINI_MODEL=gemini-2.5-flash
AGENT_MAX_RESULTS=5
AGENT_MAX_CHARS=1000
ENGINE1_THRESHOLD=50
REPUTATION_MIN_SAMPLES=3
CORROBORATION_MIN_DOMAINS=2
ENGINE2_CVE_TIMEOUT=8
ENGINE2_CVE_DELAY=0.7
ENGINE2_URL_TIMEOUT=5
MONGO_DB=nanogaze_mlops
REPORTS_DIR=reports
DASHBOARD_PORT=8080

# ADK agent target (Cloud Run URL the agent_builder tools call)
NANOGAZE_URL=https://nanogaze-42024494530.us-central1.run.app
